# SRT 로그인 정보 (회원번호/이메일/휴대폰번호 중 하나 + 비밀번호)
SRT_ID=your_srt_id_or_phone_number
SRT_PASSWORD=your_srt_password

# 예매 정보
DEP_STATION=수서
ARR_STATION=부산
TRAIN_DATE=20260710
TIME_START=060000
TIME_END=120000

# 승객 수
ADULT_COUNT=1
CHILD_COUNT=0
SENIOR_COUNT=0

# 좌석 옵션: GENERAL_FIRST(일반석 우선, 없으면 특실), SPECIAL_FIRST(특실 우선),
# GENERAL_ONLY(일반석만), SPECIAL_ONLY(특실만)
SEAT_TYPE=GENERAL_FIRST

# 좌석 조회 주기(초). 매 요청마다 이 범위 안에서 무작위 간격으로 재시도합니다.
CHECK_INTERVAL_MIN=8
CHECK_INTERVAL_MAX=15

# (선택) 텔레그램 알림 - 예매 성공/시작 시 메시지를 보냅니다.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
